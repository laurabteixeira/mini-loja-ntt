NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://mini_loja:mini_loja@localhost:5433/mini_loja
REDIS_URL=redis://localhost:6379
CACHE_TTL=60
CORS_ORIGIN=http://localhost:5173
# Rate limiting (in-memory, @nestjs/throttler). Disabled automatically when NODE_ENV=test.
THROTTLE_TTL=60000
THROTTLE_LIMIT=120
THROTTLE_HEALTH_LIMIT=10
# RUN_SEED=true runs prisma seed on container startup (docker-entrypoint.sh)
# Comma-separated origins also supported, e.g. http://localhost:5173,http://localhost:5174
# In development, any http://localhost:<port> is allowed automatically.
